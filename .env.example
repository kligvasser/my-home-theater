# my-home-theater — secrets. Copy to `.env` (never commit `.env`).

# --- Metadata APIs ---
TMDB_API_KEY=
OMDB_API_KEY=

# --- NAS / SMB ---
SMB_USER=
SMB_PASS=
# IP fallback for flaky `.local` mDNS from containers (e.g. 192.168.1.50)
SMB_HOST=

# --- Media-automation stack (the app drives these) ---
RADARR_URL=http://localhost:7878
RADARR_API_KEY=
SONARR_URL=http://localhost:8989
SONARR_API_KEY=
BAZARR_URL=http://localhost:6767
BAZARR_API_KEY=

# --- Watchlist (Trakt OAuth) ---
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Dashboard auth (required for mutating endpoints) ---
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=
